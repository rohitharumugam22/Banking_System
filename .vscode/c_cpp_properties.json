{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/src",
                "C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/*/include",
                "C:/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/VC/Tools/MSVC/*/include",
                "C:/Program Files (x86)/Windows Kits/10/Include/10.0.*/ucrt",
                "C:/Program Files (x86)/Windows Kits/10/Include/10.0.*/um",
                "C:/Program Files/Windows Kits/10/Include/*/ucrt",
                "C:/Program Files/Windows Kits/10/Include/*/um",
                "${env:WindowsSDKVersion}/ucrt",
                "${env:VCINSTALLDIR}/include"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "_WINDOWS"
            ],
            "compilerPath": "cl.exe",
            "cStandard": "c99",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/include",
                    "${workspaceFolder}/src"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
